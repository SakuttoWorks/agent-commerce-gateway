compatibility_date = "2026-03-03"
compatibility_flags = ["nodejs_compat"]
main = "src/index.ts"
name = "agent-commerce-gateway"

# =========================================================
# ▼ Routing Configuration (Custom Domain)
# =========================================================
# TODO: Replace with your actual custom domain. 
# If you are using the default workers.dev domain, you can comment this block out.
routes = [
  {pattern = "api.sakutto.works", custom_domain = true},
]

# =========================================================
# ▼ Public Environment Variables (Non-sensitive)
# =========================================================
[vars]
# Upstream Service URL (Layer B: Google Cloud Run or other backend)
# Note: For local development, this is overridden by .dev.vars
# TODO: Replace with your actual backend URL
CORE_API_URL = "https://agent-commerce-core-xd36uwybpa-an.a.run.app/"

# Environment Context (Strict Production Mode)
ENVIRONMENT = "production"

# [Priority 3] Monetization Configuration (Polar.sh)
# Product ID for metered billing
# TODO: Replace with your Polar.sh Organization and Product IDs
POLAR_ORGANIZATION_ID = "your-polar-organization-id"
POLAR_PRODUCT_ID = "your-polar-product-id"

# =========================================================
# ▼ Infrastructure Maintenance (Keep-Alive & Health Checks)
# =========================================================
# Optional: Configure a target URL for automated keep-alive requests to prevent cold starts.
KEEPALIVE_TARGET_URL = "https://api.sakutto.works/v1/health"

# Optional: If routing keep-alive requests through a custom proxy, define the host here.
CUSTOM_PROXY_HOST = ""

# =========================================================
# ▼ Automated Tasks (Cron Triggers)
# =========================================================
# Executes every 8 hours for keep-alive and background maintenance tasks.
[triggers]
crons = ["*/15 * * * *"]

# =========================================================
# ▼ Infrastructure Optimization
# =========================================================
# Smart Placement: Optimizes latency by moving execution closer to upstream Core
[placement]
mode = "smart"

# Observability & Logging
[observability]
enabled = true

# =========================================================
# ▼ Bindings (Storage, Cache & Limits)
# =========================================================
# R2 Storage Binding for Privacy-Safe Audit Logs [Phase 4: Step 2]
# TODO: Create an R2 bucket and set the name here
[[r2_buckets]]
binding = "R2_LOGS"
bucket_name = "your-r2-bucket-name"

# KV Namespace for Global Edge Caching (Polar.sh Validations) [Phase 4: Step 2]
# TODO: Create a KV namespace and set the ID here 
# (Run `npx wrangler kv:namespace create POLAR_CACHE_KV` to generate an ID)
[[kv_namespaces]]
binding = "POLAR_CACHE_KV"
id = "your-kv-namespace-id"

# Strict Rate Limiting (Workers Rate Limiting API) [Phase 4: Step 3]
[[ratelimits]]
name = "RATE_LIMITER" 
namespace_id = "1001" # Any unique string ID of your choice

[ratelimits.simple]
# TODO: Adjust these limits for your production environment
limit = 100 # Number of requests allowed (set to 100 for production)
period = 60 # Period in seconds (must be 10 or 60 according to Cloudflare specs)

# =========================================================
# ▼ Required Secrets (DO NOT HARDCODE HERE)
# =========================================================
# The following secrets must be securely set in your Cloudflare environment.
# Run the following commands to configure them:
# $ npx wrangler secret put INTERNAL_AUTH_SECRET
# $ npx wrangler secret put RESEND_API_KEY
# $ npx wrangler secret put POLAR_ACCESS_TOKEN
# $ npx wrangler secret put CUSTOM_PROXY_API_KEY